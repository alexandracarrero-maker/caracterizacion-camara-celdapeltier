% --- Gráfica: Diferencial de Temperatura: Interna vs. Ambiente ---

% 1. Tiempo de las tomas (0 a 30 minutos)
tiempo = [0, 10, 20, 30]; 

% 2. Valores exactos de la imagen
temp_interna  = [23.1, 22.8, 22.8, 22.6]; % Puntos con círculos
temp_ambiente = [26.5, 26.3, 26.0, 25.9]; % Puntos con 'X'

% 3. Crear la figura y graficar ambas curvas
figure;
plot(tiempo, temp_interna, '-o', 'LineWidth', 2, 'Color', [0.85, 0.33, 0.1]); 
hold on;
plot(tiempo, temp_ambiente, '--x', 'LineWidth', 2, 'Color', [0.5, 0.5, 0.5]); 
hold off;

% 4. Personalización estética del gráfico
title('Diferencial de Temperatura: Interna vs. Ambiente');
xlabel('Tiempo (Minutos)');
ylabel('Temperatura (°C)');
set(gca, 'XTick', [0, 10, 20, 30]);
legend('Temperatura Interna', 'Temperatura Ambiente (Externa)', 'Location', 'northeast');
grid on;
