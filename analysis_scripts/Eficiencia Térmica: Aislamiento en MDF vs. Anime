% --- Gráfica: Eficiencia Térmica: Aislamiento en MDF vs. Anime ---

% 1. Tiempo de las tomas (0 a 30 minutos)
tiempo = [0, 10, 20, 30]; 

% 2. Valores exactos tomados de la gráfica
camara_mdf   = [25.7, 25.6, 25.5, 25.4]; % Marrón con círculos
camara_anime = [23.1, 22.8, 22.7, 22.5]; % Fucsia con cuadrados

% 3. Crear la figura y graficar ambas curvas
figure;
plot(tiempo, camara_mdf, '-o', 'LineWidth', 2, 'Color', [0.5, 0.25, 0.0]); % Marrón
hold on;
plot(tiempo, camara_anime, '-s', 'LineWidth', 2, 'Color', [0.95, 0.0, 0.5]); % Fucsia
hold off;

% 4. Personalización estética del gráfico
title('Eficiencia Térmica: Aislamiento en MDF vs. Anime');
xlabel('Tiempo (Minutos)');
ylabel('Temperatura Interna (°C)');
set(gca, 'XTick', [0, 10, 20, 30]);
legend('Cámara con MDF', 'Cámara con Anime', 'Location', 'northeast');
grid on;
